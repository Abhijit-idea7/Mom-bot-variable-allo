# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secret API keys.
#
# Account definitions live in accounts.json (safe to commit).
# Add one env var pair per account, then add the account to accounts.json.

# ── Default / primary account ───────────────────────────────────────────────
STOCKSDEVELOPER_API_KEY=your-api-key-here
STOCKSDEVELOPER_ACCOUNT=AbhiZerodha

# ── Second account example (uncomment and fill in if you have a second account)
# Add a matching entry in accounts.json:
#   "abhi2": {
#     "display_name": "Second Account",
#     "api_key_env":  "STOCKSDEVELOPER_API_KEY_ABHI2",
#     "account_id_env": "STOCKSDEVELOPER_ACCOUNT_ABHI2"
#   }
#
# STOCKSDEVELOPER_API_KEY_ABHI2=your-second-api-key-here
# STOCKSDEVELOPER_ACCOUNT_ABHI2=AbhiZerodha2

# ── GitHub Actions secrets ──────────────────────────────────────────────────
# Add the same variable names as GitHub Actions secrets (repo Settings → Secrets):
#   STOCKSDEVELOPER_API_KEY
#   STOCKSDEVELOPER_ACCOUNT
#   STOCKSDEVELOPER_API_KEY_ABHI2   (if using a second account)
#   STOCKSDEVELOPER_ACCOUNT_ABHI2   (if using a second account)
